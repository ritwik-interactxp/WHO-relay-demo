<body class="signup-body" style="background: white;">
	
		<div class="agile-signup">	
				
			<div class="content2">
				
				<div class="grids-heading gallery-heading signup-heading" style="background-color: tomato;">

					<h1>WIN-IMM</h1><br>
					<h3>WHO India NPSU Information Management Module</h3>
					
				</div>
				<form action="process.php" method="post">
					<input type="text" name="user" placeholder="Username in capital letter" pattern="[A-Z0-9]{5,}" onfocus="this.value = '';" onblur="if (this.value == '') {this.value = 'Username';}">
					<input type="password" name="pass" placeholder="Password" value="" onfocus="this.value = '';" onblur="if (this.value == '') {this.value = '';}">
					<input type="submit" class="register" value="Login" style="color: black; background-color: tomato; border-color: tomato;">
				</form>

		<img src="images/mohfw.png" alt="" style="width: 200px; margin-left: 2%;padding-top: 15px; background-color: transparent;"/>
		<img src="images/logo1.jpg" alt="" style="width: 250px; margin-left: 2%;padding-top: 15px; background-color: transparent;" /> 
